diff --git a/sound/soc/bcm/cxsmtspk-pi-i2s.c b/sound/soc/bcm/cxsmtspk-pi-i2s.c
new file mode 100644
index 000000000..4c1df276a
--- /dev/null
+++ b/sound/soc/bcm/cxsmtspk-pi-i2s.c
@@ -0,0 +1,151 @@
+// SPDX-License-Identifier: GPL-2.0-only
+/*
+ * CX2092x mic array + PCM512x DAC ASoC machine driver for Raspberry Pi
+ *
+ * Capture:  CX2092x  (I2C @0x41)
+ * Playback: PCM512x  (I2C @0x4c)
+ *
+ * RPi (fe203000.i2s) is I2S master, codecs are slaves.
+ */
+
+#include <linux/module.h>
+#include <linux/of.h>
+#include <linux/of_device.h>
+#include <linux/platform_device.h>
+#include <sound/soc.h>
+#include <sound/pcm_params.h>
+
+static struct snd_soc_dai_link links[2];
+static struct snd_soc_card     cxs_card;
+
+/* shared CPU/Platform comps */
+static struct snd_soc_dai_link_component cpu_comp;
+static struct snd_soc_dai_link_component plat_comp;
+
+/* codec comps */
+static struct snd_soc_dai_link_component mic_codec_comp;
+static struct snd_soc_dai_link_component dac_codec_comp;
+
+static int cxs_hw_params(struct snd_pcm_substream *substream,
+                        struct snd_pcm_hw_params *params)
+{
+       struct snd_soc_pcm_runtime *rtd = substream->private_data;
+       struct snd_soc_dai *cpu_dai   = snd_soc_rtd_to_cpu(rtd, 0);
+       struct snd_soc_dai *codec_dai = snd_soc_rtd_to_codec(rtd, 0);
+       unsigned int ch = params_channels(params);
+       /* Pi usually drives 32 bits per slot regardless of sample width */
+       unsigned int slot_width = 32;
+       int ret;
+
+       /* Codec is clock slave */
+       ret = snd_soc_dai_set_sysclk(codec_dai, 0, 0, SND_SOC_CLOCK_IN);
+       if (ret && ret != -ENOIOCTLCMD && ret != -ENOTSUPP)
+               return ret;
+
+       ret = snd_soc_dai_set_bclk_ratio(cpu_dai, slot_width * ch);
+       if (ret && ret != -ENOIOCTLCMD && ret != -ENOTSUPP)
+               return ret;
+
+       return 0;
+}
+
+static const struct snd_soc_ops cxs_ops = {
+       .hw_params = cxs_hw_params,
+};
+
+static int cxsmtspk_probe(struct platform_device *pdev)
+{
+       struct device *dev = &pdev->dev;
+       struct device_node *np = dev->of_node;
+       struct device_node *cpu_np, *mic_np, *dac_np;
+       int ret;
+
+       if (!np)
+               return dev_err_probe(dev, -EINVAL, "no DT node\n");
+
+       cpu_np = of_parse_phandle(np, "i2s-controller", 0);
+       mic_np = of_parse_phandle(np, "mic-codec", 0);
+       dac_np = of_parse_phandle(np, "dac-codec", 0);
+       if (!cpu_np || !mic_np || !dac_np)
+               return dev_err_probe(dev, -EINVAL,
+                                    "missing i2s-controller/mic-codec/dac-codec phandle\n");
+
+       memset(&cpu_comp,        0, sizeof(cpu_comp));
+       memset(&plat_comp,       0, sizeof(plat_comp));
+       memset(&mic_codec_comp,  0, sizeof(mic_codec_comp));
+       memset(&dac_codec_comp,  0, sizeof(dac_codec_comp));
+
+       cpu_comp.of_node   = cpu_np;
+       plat_comp.of_node  = cpu_np;
+
+       mic_codec_comp.of_node  = mic_np;
+       mic_codec_comp.dai_name = "cx2092x-aif";
+
+       dac_codec_comp.of_node  = dac_np;
+       dac_codec_comp.dai_name = "pcm512x-hifi";
+
+       /* -------- Link 0: Mic capture -------- */
+       memset(&links[0], 0, sizeof(links[0]));
+       links[0].name            = "Mic-Capture";
+       links[0].stream_name     = "Mic Capture";
+       links[0].cpus            = &cpu_comp;
+       links[0].num_cpus        = 1;
+       links[0].platforms       = &plat_comp;
+       links[0].num_platforms   = 1;
+       links[0].codecs          = &mic_codec_comp;
+       links[0].num_codecs      = 1;
+       links[0].dai_fmt         = SND_SOC_DAIFMT_I2S |
+                                   SND_SOC_DAIFMT_NB_NF |
+                                   SND_SOC_DAIFMT_CBS_CFS;
+       links[0].ops             = &cxs_ops;
+       links[0].capture_only    = 1;
+
+       /* -------- Link 1: DAC playback -------- */
+       memset(&links[1], 0, sizeof(links[1]));
+       links[1].name            = "DAC-Playback";
+       links[1].stream_name     = "DAC Playback";
+       links[1].cpus            = &cpu_comp;
+       links[1].num_cpus        = 1;
+       links[1].platforms       = &plat_comp;
+       links[1].num_platforms   = 1;
+       links[1].codecs          = &dac_codec_comp;
+       links[1].num_codecs      = 1;
+       links[1].dai_fmt         = links[0].dai_fmt;
+       links[1].ops             = &cxs_ops;
+       links[1].playback_only   = 1;
+
+       memset(&cxs_card, 0, sizeof(cxs_card));
+       cxs_card.name      = "CXSMTSPK_Pi"; /* <= 32 chars */
+       cxs_card.owner     = THIS_MODULE;
+       cxs_card.dev       = dev;
+       cxs_card.dai_link  = links;
+       cxs_card.num_links = ARRAY_SIZE(links);
+
+       dev_dbg(dev, "registering card (cpu=%pOF, mic=%pOF, dac=%pOF)\n",
+               cpu_np, mic_np, dac_np);
+
+       ret = devm_snd_soc_register_card(dev, &cxs_card);
+       if (ret)
+               return dev_err_probe(dev, ret, "register_card failed");
+       dev_info(dev, "ASoC card registered\n");
+       return 0;
+}
+
+static const struct of_device_id cxsmtspk_of_match[] = {
+       { .compatible = "cnxt,cx2092x-pi-i2s" },
+       { /* sentinel */ }
+};
+MODULE_DEVICE_TABLE(of, cxsmtspk_of_match);
+
+static struct platform_driver cxsmtspk_driver = {
+       .driver = {
+               .name           = "snd-soc-cxsmtspk-pi-i2s",
+               .of_match_table = cxsmtspk_of_match,
+       },
+       .probe = cxsmtspk_probe,
+};
+module_platform_driver(cxsmtspk_driver);
+
+MODULE_AUTHOR("Robert Zaage");
+MODULE_DESCRIPTION("ASoC machine driver for CX2092x mic + PCM512x DAC on Raspberry Pi");
+MODULE_LICENSE("GPL");
