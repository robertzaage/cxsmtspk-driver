@@ -0,0 +1,60 @@
+/dts-v1/;
+/plugin/;
+
+/ {
+       compatible = "brcm,bcm2835";
+
+       fragment@0 {
+               target = <&i2s>;
+               __overlay__ {
+                       status = "okay";
+               };
+       };
+
+       fragment@1 {
+               target-path = "/";
+               __overlay__ {
+                       sound: cxsmtspk_sound {
+                               compatible = "cnxt,cx2092x-pi-i2s";
+                               model = "CXSMTSPK_Pi";
+                               status = "okay";
+
+                               i2s-controller = <&i2s>;
+                               mic-codec      = <&cx2092x>;
+                               dac-codec      = <&pcm512x>;
+                       };
+               };
+       };
+
+       fragment@2 {
+               target = <&i2c1>;         /* adjust if not using I2C1 */
+               __overlay__ {
+                       #address-cells = <1>;
+                       #size-cells = <0>;
+
+                       cx2092x: codec@41 {
+                               compatible = "cnxt,cx20921";
+                               reg = <0x41>;
+                               status = "okay";
+                               reset-gpios = <&gpio 22 0>;
+                       };
+
+                       pcm512x: codec@4c {
+                               compatible = "ti,pcm5122";
+                               reg = <0x4c>;
+                               status = "okay";
+                               /* Optional supplies / reset if wired:
+                                  avdd-supply = <&vdd_3v3>;
+                                  dvdd-supply = <&vdd_3v3>;
+                                  cpvdd-supply = <&vdd_3v3>;
+                                  reset-gpios = <&gpio 5 GPIO_ACTIVE_LOW>;
+                               */
+                       };
+               };
+       };
+
+       __overrides__ {
+               i2c_bus  = <&i2c1>;
+               mic_addr = <&cx2092x>,"reg:0";
+               dac_addr = <&pcm512x>,"reg:0";
+       };
+};
